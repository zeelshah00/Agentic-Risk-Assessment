# Environment variables for BigID MCP App

# Google Cloud Configuration
# The application will automatically detect GCP project and location using native gcloud/IAM authentication

# STDIO MCP Server Security Configuration
# Comma-separated list of safe hostnames that are allowed to use STDIO MCP servers
# Supports wildcards (e.g., *.aws.env.fyi will match any subdomain of aws.env.fyi)
# Examples:
STDIO_SAFE_HOSTNAMES=*.aws.env.fyi,localhost,dev.bigid.com,*.internal.company.com

# OAuth Configuration
# Base URL for OAuth callbacks (e.g., http://localhost:3000, https://your-domain.com)
OAUTH_CALLBACK_BASE_URL=http://localhost:3000

# Usage Limits Configuration (per environment)
# Daily token limit for AI API usage - set to 0 for unlimited
DAILY_TOKEN_LIMIT=10000

# Environment identifier for usage tracking
ENVIRONMENT_NAME=development

# Firestore database name for token usage tracking (set by Terraform in Cloud Run)
# For local development, you can use the default database or specify a custom one
# FIRESTORE_DATABASE=(default)
# FIRESTORE_DATABASE=bigid-agentic-app-usage-dev

# Other configurations...
PORT=3000
